<script>
// Stars
const starsEl=document.getElementById('stars');
for(let i=0;i<80;i++){
  const s=document.createElement('div');
  s.className='star';
  const size=Math.random()*2.5+.5;
  s.style.cssText=`width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${2+Math.random()*4}s;--delay:-${Math.random()*4}s`;
  starsEl.appendChild(s);
}

// Reveal on scroll
const reveals=document.querySelectorAll('.reveal');
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}});
},{threshold:.12});
reveals.forEach(r=>io.observe(r));

// Day accordion
document.querySelectorAll('.day').forEach(day=>{
  day.addEventListener('click',()=>{
    const wasActive=day.classList.contains('active');
    document.querySelectorAll('.day').forEach(d=>d.classList.remove('active'));
    if(!wasActive) day.classList.add('active');
  });
});

// Smooth nav shadow on scroll
window.addEventListener('scroll',()=>{
  document.querySelector('nav').style.boxShadow=window.scrollY>40?'0 4px 24px rgba(0,0,0,.08)':'none';
});
</script>
</body>
</html>
